{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "McpServer": {
    "Instructions": "This is a MCP server with OAuth authorization enabled."

  },
  "McpAuth": {
    "AuthServers": [ "<your-client-id>" ],
    "ResourceUri": "http://localhost:7071" // Added ResourceUri for local development
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "yourtenant.onmicrosoft.com",
    "TenantId": "<TENANT_ID>",
    "ClientId": "<API_CLIENT_ID>",
    "Audience": "<API_CLIENT_ID>"
  },
  "ProtectedResource": {
    "ValidateSignature": true,
    "JwksRefreshIntervalHours": 24
  }
}
